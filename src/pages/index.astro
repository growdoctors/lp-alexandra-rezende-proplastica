---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/HeroSection.astro';
import LocationBar from '@/components/LocationBar.astro';
import TestimonialsCarousel from '@/components/TestimonialsCarousel';
import DesiresSection from '@/components/DesiresSection.astro';
import VideoSection from '@/components/VideoSection.astro';
import ProcessSection from '@/components/ProcessSection.astro';
import TestimonialsSection from '@/components/TestimonialsSection.astro';
import VisitSection from '@/components/VisitSection';
import AboutSection from '@/components/AboutSection.astro';
import Footer from '@/components/Footer.astro';
---

<Layout>
  <main class="lp-main">
    <HeroSection />
    <LocationBar />
    <TestimonialsCarousel client:idle />
    <DesiresSection />
    <VideoSection />
    <ProcessSection />
    <TestimonialsSection />
    <VisitSection client:idle />
    <AboutSection />
    <Footer />
  </main>
</Layout>
