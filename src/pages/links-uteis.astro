---
import { CLIENT } from '@/config/client';
import '@/styles/global.css';

const fontDisplay = (CLIENT as any).fonts?.display ?? 'Montserrat';
const fontBody = (CLIENT as any).fonts?.body ?? 'Montserrat';
const seoTitle = `Links Úteis — ${CLIENT.name}`;
const items = [
  { label: 'Agende sua consulta no WhatsApp', href: CLIENT.whatsappUrl },
  { label: 'Política de privacidade', href: CLIENT.footer.privacyHref },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seoTitle}</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href={CLIENT.favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={CLIENT.fontsUrl} rel="stylesheet" />
    <style is:inline set:html={`:root{--font-display:'${fontDisplay}',Georgia,serif;--font-body:'${fontBody}',sans-serif;}`}></style>
  </head>
  <body class="lu-body">
    <main class="lu-main">
      <div class="lu-avatar-wrap">
        <img
          src={CLIENT.logo}
          alt={CLIENT.name}
          class="lu-avatar lu-avatar--logo"
          width="120"
          height="42"
        />
      </div>

      <p class="lu-name">{CLIENT.name}</p>
      <p class="lu-specialty">Atendimento e informações</p>

      <div class="lu-rule" aria-hidden="true"></div>

      <ul class="lu-list">
        {items.map((item) => (
          <li>
            <a href={item.href} target="_blank" rel="noopener noreferrer" class="lu-btn">
              {item.label}
              <span class="lu-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>

      <a href="/" class="lu-back">← Voltar para a página principal</a>
    </main>

    <footer class="lu-footer">
      <img src={CLIENT.logo} alt={CLIENT.name} class="lu-footer-logo" />
      <p class="lu-footer-copy">© {CLIENT.footer.year} {CLIENT.footer.copyright}</p>
    </footer>
  </body>
</html>

<style>
  .lu-body {
    margin: 0;
    min-height: 100dvh;
    background: var(--lp-dark);
    display: flex;
    flex-direction: column;
    font-family: var(--font-body);
  }
  .lu-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: min(460px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0 2rem;
  }
  .lu-avatar-wrap {
    width: 132px;
    height: 132px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .lu-avatar--logo {
    width: 92px;
    height: auto;
    object-fit: contain;
  }
  .lu-name {
    margin: 0;
    color: #fff;
    font-size: 1.55rem;
    font-weight: 700;
    text-align: center;
  }
  .lu-specialty {
    margin: 0.45rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    text-align: center;
    font-size: 0.92rem;
  }
  .lu-rule {
    width: 52px;
    height: 1px;
    background: rgba(255, 255, 255, 0.26);
    margin: 1.5rem 0;
  }
  .lu-list {
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }
  .lu-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 1.15rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-weight: 600;
    transition: background 180ms ease, transform 180ms ease;
  }
  .lu-btn:hover {
    background: rgba(255, 255, 255, 0.14);
    transform: translateY(-1px);
  }
  .lu-back {
    margin-top: 1.5rem;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.88rem;
  }
  .lu-footer {
    padding: 1.5rem 1rem 2rem;
    text-align: center;
  }
  .lu-footer-logo {
    width: 92px;
    margin: 0 auto 0.75rem;
  }
  .lu-footer-copy {
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.78rem;
  }
</style>
