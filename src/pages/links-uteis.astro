---
import { CLIENT } from '@/config/client';
import '@/styles/global.css';

const doctor = CLIENT.doctors[0];
const fontDisplay = (CLIENT as any).fonts?.display ?? 'Cormorant Garamond';
const fontBody    = (CLIENT as any).fonts?.body    ?? 'Montserrat';
const { items } = CLIENT.linksUteis;
const seoTitle = `Links Úteis — ${CLIENT.name}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seoTitle}</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href={CLIENT.favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={CLIENT.fontsUrl} rel="stylesheet" />
    <style is:inline set:html={`:root{--font-display:'${fontDisplay}',Georgia,serif;--font-body:'${fontBody}',sans-serif;}`}></style>
  </head>
  <body class="lu-body">

    <main class="lu-main">

      <!-- Avatar / foto do médico -->
      <div class="lu-avatar-wrap">
        <img
          src={doctor.photo}
          alt={doctor.name}
          class="lu-avatar"
          width="96"
          height="96"
        />
      </div>

      <!-- Nome e especialidade -->
      <p class="lu-name">{doctor.name}</p>
      <p class="lu-specialty">{doctor.specialty}</p>

      <!-- Separador dourado -->
      <div class="lu-rule" aria-hidden="true"></div>

      <!-- Lista de links -->
      {items.length > 0 ? (
        <ul class="lu-list">
          {items.map((item) => (
            <li>
              <a href={item.href} target="_blank" rel="noopener noreferrer" class="lu-btn">
                {item.label}
                <span class="lu-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="lu-empty">Nenhum link cadastrado.</p>
      )}

      <!-- Botão de volta para a LP -->
      <a href="/" class="lu-back">← Voltar para a página principal</a>

    </main>

    <!-- UTM Propagator — propaga UTMs da URL para links clicados na página -->
    <script is:inline>
      (function(){
        var KEYS=['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid','fbclid'];
        var SKIP=['instagram.com','share.google','google.com/maps','waze.com','privacidade.growdoc'];
        var pageQ=new URLSearchParams(window.location.search);
        var captured=new URLSearchParams();
        var hasUTM=false;
        KEYS.forEach(function(k){
          if(pageQ.has(k)){captured.set(k,pageQ.get(k));hasUTM=true;}
        });
        if(!hasUTM)return;
        function build(href){
          try{
            var u=new URL(href);
            KEYS.forEach(function(k){u.searchParams.delete(k);});
            captured.forEach(function(v,k){u.searchParams.set(k,v);});
            return u.toString();
          }catch(e){return href;}
        }
        function skip(href){
          if(!href||href[0]==='#'||href.indexOf('elementor-action')>-1)return true;
          return SKIP.some(function(d){return href.indexOf(d)>-1;});
        }
        document.addEventListener('click',function(e){
          var a=e.target.closest('a[href]');
          if(!a)return;
          var href=a.getAttribute('href')||'';
          if(skip(href))return;
          var novo=build(a.href);
          if(novo===a.href)return;
          e.preventDefault();
          var target=a.getAttribute('target');
          if(target==='_blank'){window.open(novo,'_blank');}
          else{window.location.href=novo;}
        },true);
      })();
    </script>

    <!-- Logo da clínica no rodapé -->
    <footer class="lu-footer">
      <img src={CLIENT.logo} alt={CLIENT.name} class="lu-footer-logo" />
      <p class="lu-footer-copy">© {CLIENT.footer.year} {CLIENT.footer.copyright}</p>
    </footer>

  </body>
</html>

<style>
  .lu-body {
    margin: 0;
    min-height: 100dvh;
    background: var(--lp-dark, #1a1612);
    display: flex;
    flex-direction: column;
    font-family: var(--font-body, 'Montserrat', sans-serif);
  }

  .lu-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48px 24px 32px;
    max-width: 480px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  .lu-avatar-wrap {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--lp-gold, #C4A36E);
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .lu-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lu-name {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 4px;
    text-align: center;
  }

  .lu-specialty {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lp-gold, #C4A36E);
    margin: 0;
    text-align: center;
  }

  .lu-rule {
    width: 40px;
    height: 1px;
    background: var(--lp-gold, #C4A36E);
    opacity: 0.5;
    margin: 20px 0 24px;
  }

  .lu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .lu-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(196, 163, 110, 0.3);
    border-radius: 6px;
    color: #fff;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
    box-sizing: border-box;
  }

  .lu-btn:hover {
    background: rgba(196, 163, 110, 0.12);
    border-color: var(--lp-gold, #C4A36E);
  }

  .lu-arrow {
    color: var(--lp-gold, #C4A36E);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .lu-empty {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.85rem;
    text-align: center;
    margin: 0;
  }

  .lu-back {
    margin-top: 32px;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .lu-back:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .lu-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 24px;
    border-top: 1px solid rgba(196, 163, 110, 0.1);
  }

  .lu-footer-logo {
    height: 36px;
    width: auto;
    object-fit: contain;
    opacity: 0.6;
  }

  .lu-footer-copy {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
    margin: 0;
    text-align: center;
  }
</style>
