          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- FAB button -->
  <button class="waw-btn" id="waw-btn" aria-label="Abrir chat WhatsApp" aria-expanded="false">
    <svg class="waw-icon waw-icon--open" viewBox="0 0 24 24" fill="white" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <svg class="waw-icon waw-icon--close" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>

</div>

<style>
  .waw-root {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9998;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* Panel */
  .waw-panel {
    width: 320px;
    border-radius: 16px;
    background: #fff;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
    overflow: hidden;
    transform-origin: bottom right;
    transform: scale(0.85) translateY(8px);
    opacity: 0;
    pointer-events: none;
    transition: transform 240ms cubic-bezier(0.34,1.56,0.64,1), opacity 200ms ease;
  }

  .waw-panel.is-open {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .waw-header {
    background: #25d366;
    padding: 1.1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .waw-header-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }

  .waw-header-title {
    margin: 0 0 2px;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .waw-header-sub {
    margin: 0;
    color: rgba(255,255,255,0.85);
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .waw-body {
    padding: 1rem 1.25rem 1.25rem;
    background: #f0f0f0;
  }

  .waw-reply-note {
    margin: 0 0 0.85rem;
    color: #888;
    font-size: 0.75rem;
  }

  /* Contact card */
  .waw-contact {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: #fff;
    border-radius: 10px;
    text-decoration: none;
    box-shadow: 0 1px 6px rgba(0,0,0,0.08);
    transition: box-shadow 160ms ease;
  }

  .waw-contact:hover {
    box-shadow: 0 3px 12px rgba(0,0,0,0.14);
  }

  .waw-contact-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .waw-contact-avatar svg {
    width: 22px;
    height: 22px;
  }

  .waw-contact-info {
    flex: 1;
    min-width: 0;
  }

  .waw-contact-name {
    margin: 0 0 2px;
    color: #111;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .waw-contact-msg {
    margin: 0;
    color: #777;
    font-size: 0.75rem;
    line-height: 1.35;
  }

  .waw-contact-wa {
    width: 22px;
    height: 22px;
    fill: #25d366;
    flex-shrink: 0;
  }

  /* FAB button */
  .waw-btn {
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: #25d366;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37,211,102,0.45);
    transition: transform 200ms ease, box-shadow 200ms ease;
    flex-shrink: 0;
  }

  .waw-btn:hover {
    transform: scale(1.07);
    box-shadow: 0 6px 24px rgba(37,211,102,0.55);
  }

  .waw-icon {
    width: 28px;
    height: 28px;
    position: absolute;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .waw-icon--close {
    opacity: 0;
    transform: rotate(-90deg);
  }

  .waw-btn.is-open .waw-icon--open {
    opacity: 0;
    transform: rotate(90deg);
  }

  .waw-btn.is-open .waw-icon--close {
    opacity: 1;
    transform: rotate(0deg);
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('waw-btn');
    var panel = document.getElementById('waw-panel');
    if (!btn || !panel) return;

    var open = false;

    btn.addEventListener('click', function () {
      open = !open;
      btn.classList.toggle('is-open', open);
      panel.classList.toggle('is-open', open);
      panel.setAttribute('aria-hidden', String(!open));
      btn.setAttribute('aria-expanded', String(open));
    });

    document.addEventListener('click', function (e) {
      if (open && !document.getElementById('waw-root').contains(e.target)) {
        open = false;
        btn.classList.remove('is-open');
        panel.classList.remove('is-open');
        panel.setAttribute('aria-hidden', 'true');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
