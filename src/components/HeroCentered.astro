---
// HeroCentered — hero centralizado, fundo escuro sólido ou gradiente
// Ideal quando a copy é curta e impactante, ou quando não há foto de fundo.
// Não usa bg-hero.png — fundo é var(--lp-dark) com partículas/gradiente decorativo.
import { CLIENT } from '@/config/client';
import HeroForm from './HeroForm';

const { hero } = CLIENT;
const lastLine = hero.headingLines[hero.headingLines.length - 1];
const firstLines = hero.headingLines.slice(0, -1);
---

<section class="hc-section">
  <!-- Decoração: gradiente radial suave atrás do conteúdo -->
  <div class="hc-glow" aria-hidden="true"></div>

  <div class="hc-inner">

    <img
      src={CLIENT.logo}
      alt={CLIENT.name}
      width="180"
      height="90"
      fetchpriority="high"
      style="height:68px;width:auto;object-fit:contain;animation:heroSlideDown 0.55s cubic-bezier(0.16,1,0.3,1) both;"
    />

    <p class="hc-eyebrow" style="animation:heroSlideUp 0.55s cubic-bezier(0.16,1,0.3,1) 0.1s both;">{hero.eyebrow}</p>

    <!-- Linha dourada decorativa acima do heading -->
    <div class="hc-rule" style="animation:sepGrow 0.6s cubic-bezier(0.16,1,0.3,1) 0.18s forwards;opacity:0;"></div>

    <h1 class="hc-heading" style="animation:heroSlideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.22s both;">
      {firstLines.map(line => <span style="display:block">{line}</span>)}
      <em>{lastLine}</em>
    </h1>

    <div class="hc-creds" style="animation:heroSlideUp 0.55s cubic-bezier(0.16,1,0.3,1) 0.38s both;">
      {hero.credentials.map(cred => <p>{cred}</p>)}
    </div>

    <div class="hc-form-wrap" style="animation:heroSlideUp 0.55s cubic-bezier(0.16,1,0.3,1) 0.46s both;">
      <HeroForm client:load />
    </div>

  </div>
</section>

<style>
  .hc-section {
    width: 100%;
    min-height: 100dvh;
    background: var(--lp-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  /* Gradiente dourado difuso — dá profundidade sem peso */
  .hc-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    width: 900px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(196,163,110,0.07) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hc-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 80px 24px;
    width: 100%;
    max-width: 780px;
    margin: 0 auto;
  }

  .hc-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--lp-gold);
    margin: 24px 0 20px;
  }

  .hc-rule {
    width: 48px;
    height: 2px;
    background: var(--lp-gold);
    border-radius: 2px;
    margin-bottom: 24px;
  }

  .hc-heading {
    font-family: var(--font-display);
    font-size: clamp(44px, 6vw, 80px);
    font-weight: 400;
    color: #fff;
    line-height: 1.05;
    margin: 0 0 28px;
    letter-spacing: -0.02em;
  }
  .hc-heading em {
    font-style: italic;
    color: var(--lp-gold);
  }

  .hc-creds {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 36px;
  }
  .hc-creds p {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: rgba(232,231,218,0.55);
    margin: 0;
    letter-spacing: 0.06em;
  }

  .hc-form-wrap {
    width: 100%;
    max-width: 520px;
  }

  @media (max-width: 640px) {
    .hc-heading { font-size: clamp(36px, 9vw, 52px); }
    .hc-inner { padding: 64px 20px; }
  }
</style>
