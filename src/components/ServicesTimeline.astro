---
// ServicesTimeline — variação de ServicesSection com layout de lista editorial
// Mesmos dados de services em client.ts, visual completamente diferente:
// número grande à esquerda, título + descrição à direita, fundo escuro.
import { CLIENT } from '@/config/client';

const { services } = CLIENT;
---

<section class="lp-section-pad" style="background-color: var(--lp-dark)">
  <div class="lp-section-inner">

    <div class="reveal" style="text-align:center;margin-bottom:72px">
      <span class="lp-eyebrow">{services.eyebrow}</span>
      <h2 class="lp-section-heading" style="font-size:clamp(30px,4vw,48px);color:#fff;text-align:center;margin-top:8px">
        {services.heading} <em style="font-style:italic;color:var(--lp-gold)">{services.headingEm}</em>
      </h2>
      <div class="lp-gold-rule" style="margin-top:20px"></div>
    </div>

    <div class="st-list">
      {services.items.map((item, idx) => (
        <div class={`st-item reveal${idx % 2 === 1 ? ' st-item--alt' : ''}`}>
          <div class="st-num-col" aria-hidden="true">
            <span class="st-num">{item.num}</span>
          </div>
          <div class="st-divider" aria-hidden="true"></div>
          <div class="st-content">
            <h3 class="st-title">{item.title}</h3>
            <p class="st-desc">{item.description}</p>
          </div>
          <a href="#utmCaptureForm" class="st-arrow" aria-label={`Saber mais sobre ${item.title}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

    <div style="text-align:center;margin-top:64px" class="reveal">
      <a href="#utmCaptureForm" class="btn-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        AGENDAR CONSULTA
      </a>
    </div>

  </div>
</section>

<style>
  .st-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(196,163,110,0.12);
  }

  .st-item {
    display: grid;
    grid-template-columns: 100px 1px 1fr auto;
    gap: 0 32px;
    align-items: center;
    padding: 28px 0;
    border-bottom: 1px solid rgba(196,163,110,0.12);
    transition: background 0.25s ease;
  }
  .st-item:hover { background: rgba(196,163,110,0.03); }

  /* Linhas alternadas têm número levemente diferente */
  .st-item--alt .st-num { opacity: 0.45; }

  .st-num-col {
    display: flex;
    justify-content: flex-start;
    padding-left: 4px;
  }

  .st-num {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 300;
    color: var(--lp-gold);
    line-height: 1;
    opacity: 0.6;
    letter-spacing: -0.02em;
  }

  .st-divider {
    width: 1px;
    height: 40px;
    background: rgba(196,163,110,0.2);
    flex-shrink: 0;
  }

  .st-content {
    padding: 4px 0;
  }

  .st-title {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #F7F4EF;
    margin: 0 0 8px;
  }

  .st-desc {
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(232,231,218,0.55);
    line-height: 1.65;
    margin: 0;
    max-width: 600px;
  }

  .st-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(196,163,110,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lp-gold);
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .st-arrow:hover {
    background: var(--lp-gold);
    border-color: var(--lp-gold);
    color: var(--lp-dark);
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .st-item {
      grid-template-columns: 64px 1px 1fr auto;
      gap: 0 20px;
      padding: 22px 0;
    }
    .st-num { font-size: 36px; }
    .st-divider { height: 32px; }
    .st-arrow { width: 36px; height: 36px; }
    .st-desc { font-size: 13px; }
  }

  @media (max-width: 480px) {
    .st-item { grid-template-columns: 52px 1fr; gap: 0 16px; }
    .st-divider { display: none; }
    .st-arrow { display: none; }
  }
</style>
