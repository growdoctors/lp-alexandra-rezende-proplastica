---
// DesiresIcons — variação de DesiresSection com ícones SVG por problema
// Mesmos dados de desires em client.ts + campo opcional icon (SVG inline string)
// Se icon não for definido, usa um ícone padrão de check.
import { CLIENT } from '@/config/client';

const { desires } = CLIENT;

// Ícone padrão: check circle dourado
const DEFAULT_ICON = `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
---

<section class="lp-section-pad" style="background-color: var(--lp-dark)">
  <div class="lp-section-inner">

    <div class="reveal" style="text-align:center;margin-bottom:48px">
      <span class="lp-eyebrow">{desires.eyebrow}</span>
      <h2 class="lp-section-heading" style="font-size:clamp(32px,4vw,48px);color:#fff;text-align:center;margin-top:8px">
        {desires.heading}
      </h2>
      <div class="lp-gold-rule" style="margin-top:20px"></div>
    </div>

    <div class="di-grid reveal-list">
      {desires.items.map(item => {
        const icon = (item as any).icon as string | undefined ?? DEFAULT_ICON;
        return (
          <div class="di-card">
            <div class="di-icon-wrap" set:html={icon} aria-hidden="true" />
            <p class="di-text">{item.text}</p>
          </div>
        );
      })}
    </div>

    <div style="text-align:center;margin-top:48px" class="reveal">
      <p class="di-subtext">{desires.ctaSubtext}</p>
      <a href="#utmCaptureForm" class="btn-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        AGENDAR CONSULTA
      </a>
    </div>

  </div>
</section>

<style>
  .di-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .di-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(196,163,110,0.15);
    border-radius: 20px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }
  .di-card:hover {
    background: rgba(196,163,110,0.07);
    border-color: rgba(196,163,110,0.35);
    transform: translateY(-3px);
  }

  /* Ícone — herda cor do pai como gold */
  .di-icon-wrap {
    color: var(--lp-gold);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(196,163,110,0.1);
    border-radius: 12px;
    flex-shrink: 0;
  }
  .di-icon-wrap svg {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .di-text {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: #fff;
    line-height: 1.55;
    margin: 0;
  }

  .di-subtext {
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    color: var(--lp-gold);
    margin: 0 0 28px;
  }

  @media (max-width: 640px) {
    .di-grid { grid-template-columns: 1fr; }
  }
</style>
