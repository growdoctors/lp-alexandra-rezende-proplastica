---
import { CLIENT } from '@/config/client';

const { aboutSection } = CLIENT;
---

<section class="lp-section-pad lp-about-section">
  <div class="lp-section-inner lp-section-inner--wide lp-about-layout">
    <div class="reveal lp-about-media">
      <img src={aboutSection.image} alt={aboutSection.heading} class="lp-about-image" loading="lazy" decoding="async" />
    </div>

    <div class="reveal lp-about-panel">
      <p class="lp-about-eyebrow">{aboutSection.eyebrow}</p>
      <h2 class="lp-section-heading lp-about-heading">{aboutSection.heading}</h2>
      <div class="lp-about-copy">
        {aboutSection.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <ul class="lp-about-list">
        {aboutSection.bullets.map((item) => (
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <a href={CLIENT.whatsappUrl} target="_blank" rel="noopener" class="btn-cta lp-about-cta">
        AGENDAR CONSULTA
      </a>
    </div>
  </div>
</section>
