---
import { CLIENT } from '@/config/client';

const process = (CLIENT as any).process as {
  eyebrow: string;
  heading: string;
  headingEm?: string;
  steps: { num: string; title: string; description: string }[];
};
---

<section class="lp-section-pad" style="background-color: var(--lp-cream)">
  <div class="lp-section-inner">

    <div class="reveal" style="text-align:center;margin-bottom:64px">
      <span class="lp-eyebrow">{process.eyebrow}</span>
      <h2 class="lp-section-heading" style="font-size:clamp(28px,3.5vw,44px);color:var(--lp-dark);text-align:center;margin-top:8px">
        {process.heading}{process.headingEm && <> <em style="font-style:italic;color:var(--lp-gold)">{process.headingEm}</em></>}
      </h2>
      <div class="lp-gold-rule" style="margin-top:20px"></div>
    </div>

    <div class="process-steps">
      {process.steps.map((step, idx) => (
        <div class="process-item reveal">
          <!-- Linha vertical conectora (exceto no último) -->
          {idx < process.steps.length - 1 && (
            <div class="process-line" aria-hidden="true"></div>
          )}
          <div class="process-num-wrap" aria-hidden="true">
            <span class="process-num">{step.num}</span>
          </div>
          <div class="process-content">
            <h3 class="process-title">{step.title}</h3>
            <p class="process-desc">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div style="text-align:center;margin-top:56px" class="reveal">
      <a href="#utmCaptureForm" class="btn-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        AGENDAR CONSULTA
      </a>
    </div>

  </div>
</section>

<style>
  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 760px;
    margin: 0 auto;
  }

  .process-item {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 0 28px;
    position: relative;
  }

  .process-num-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 4px;
    position: relative;
    z-index: 1;
  }

  .process-num {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--lp-dark);
    border: 2px solid rgba(196,163,110,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--lp-gold);
    flex-shrink: 0;
    box-shadow: 0 0 0 6px rgba(196,163,110,0.06);
  }

  /* Linha vertical conectora */
  .process-line {
    position: absolute;
    left: 25px;
    top: 56px;
    bottom: -28px;
    width: 2px;
    background: linear-gradient(to bottom, rgba(196,163,110,0.35), rgba(196,163,110,0.08));
  }

  .process-content {
    padding: 6px 0 48px;
  }

  .process-title {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lp-dark);
    margin: 0 0 10px;
  }

  .process-desc {
    font-family: var(--font-body);
    font-size: 15px;
    color: #6b6150;
    line-height: 1.75;
    margin: 0;
  }

  .process-item:last-child .process-content {
    padding-bottom: 0;
  }

  @media (max-width: 640px) {
    .process-item {
      grid-template-columns: 48px 1fr;
      gap: 0 20px;
    }
    .process-num {
      width: 42px;
      height: 42px;
      font-size: 18px;
    }
    .process-line {
      left: 19px;
      top: 46px;
    }
    .process-content {
      padding-bottom: 36px;
    }
  }
</style>
