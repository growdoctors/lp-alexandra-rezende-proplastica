---
import { CLIENT } from '@/config/client';

const beforeAfter = (CLIENT as any).beforeAfter as {
  eyebrow: string;
  heading: string;
  headingEm?: string;
  disclaimer?: string;
  items: { label: string; beforeSrc: string; afterSrc: string; beforeAlt?: string; afterAlt?: string }[];
};
---

<section class="lp-section-pad" style="background-color: var(--lp-dark)">
  <div class="lp-section-inner">

    <div class="reveal" style="text-align:center;margin-bottom:56px">
      <span class="lp-eyebrow">{beforeAfter.eyebrow}</span>
      <h2 class="lp-section-heading" style="font-size:clamp(28px,3.5vw,44px);color:#fff;text-align:center;margin-top:8px">
        {beforeAfter.heading}{beforeAfter.headingEm && <> <em style="font-style:italic;color:var(--lp-gold)">{beforeAfter.headingEm}</em></>}
      </h2>
      <div class="lp-gold-rule" style="margin-top:20px"></div>
    </div>

    <div class="ba-grid reveal-list">
      {beforeAfter.items.map(item => (
        <div class="ba-card lp-card-lift">
          <div class="ba-images">
            <!-- Antes -->
            <div class="ba-half">
              <img
                src={item.beforeSrc}
                alt={item.beforeAlt ?? `Antes — ${item.label}`}
                loading="lazy"
                decoding="async"
                class="ba-img"
              />
              <span class="ba-label ba-label--before">ANTES</span>
            </div>
            <!-- Divisor -->
            <div class="ba-divider" aria-hidden="true">
              <div class="ba-divider-line"></div>
              <div class="ba-divider-circle">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </div>
            </div>
            <!-- Depois -->
            <div class="ba-half">
              <img
                src={item.afterSrc}
                alt={item.afterAlt ?? `Depois — ${item.label}`}
                loading="lazy"
                decoding="async"
                class="ba-img"
              />
              <span class="ba-label ba-label--after">DEPOIS</span>
            </div>
          </div>
          <p class="ba-case-label">{item.label}</p>
        </div>
      ))}
    </div>

    {beforeAfter.disclaimer && (
      <p class="ba-disclaimer reveal">{beforeAfter.disclaimer}</p>
    )}

    <div style="text-align:center;margin-top:48px" class="reveal">
      <a href="#utmCaptureForm" class="btn-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        QUERO MEU RESULTADO
      </a>
    </div>

  </div>
</section>

<style>
  .ba-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .ba-card {
    background: rgba(255,255,255,0.03);
    border-radius: 18px;
    border: 1px solid rgba(196,163,110,0.12);
    overflow: hidden;
  }

  .ba-images {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    height: clamp(220px, 30vw, 360px);
    overflow: hidden;
  }

  .ba-half {
    position: relative;
    overflow: hidden;
  }
  .ba-half:first-child { border-radius: 0; }

  .ba-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .ba-card:hover .ba-img { transform: scale(1.04); }

  .ba-label {
    position: absolute;
    top: 12px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 4px 10px;
    border-radius: 4px;
  }
  .ba-label--before {
    left: 10px;
    background: rgba(26,22,18,0.75);
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.15);
  }
  .ba-label--after {
    right: 10px;
    background: var(--lp-gold);
    color: var(--lp-dark);
  }

  .ba-divider {
    width: 2px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  .ba-divider-line {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent, var(--lp-gold) 20%, var(--lp-gold) 80%, transparent);
    opacity: 0.6;
  }
  .ba-divider-circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--lp-dark);
    border: 1.5px solid var(--lp-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lp-gold);
    position: relative;
    z-index: 3;
    flex-shrink: 0;
    gap: 0;
  }

  .ba-case-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(196,163,110,0.7);
    text-align: center;
    padding: 14px 20px;
    margin: 0;
    border-top: 1px solid rgba(196,163,110,0.1);
  }

  .ba-disclaimer {
    font-family: var(--font-body);
    font-size: 11px;
    color: rgba(255,255,255,0.25);
    text-align: center;
    margin: 24px auto 0;
    max-width: 600px;
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .ba-grid { grid-template-columns: 1fr; }
  }
</style>
