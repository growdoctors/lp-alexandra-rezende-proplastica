---
import { CLIENT } from '@/config/client';

const faq = (CLIENT as any).faq as {
  eyebrow: string;
  heading: string;
  items: { question: string; answer: string }[];
};
---

<section class="lp-section-pad" style="background-color: var(--lp-dark)">
  <div class="lp-section-inner">

    <div class="reveal" style="text-align:center;margin-bottom:56px">
      <span class="lp-eyebrow">{faq.eyebrow}</span>
      <h2 class="lp-section-heading" style="font-size:clamp(28px,3.5vw,44px);color:#fff;text-align:center;margin-top:8px">
        {faq.heading}
      </h2>
      <div class="lp-gold-rule" style="margin-top:20px"></div>
    </div>

    <div class="faq-list reveal-list" style="max-width:800px;margin:0 auto">
      {faq.items.map((item, idx) => (
        <details class="faq-item" name="faq">
          <summary class="faq-question">
            <span class="faq-q-num">{String(idx + 1).padStart(2, '0')}</span>
            <span class="faq-q-text">{item.question}</span>
            <span class="faq-icon" aria-hidden="true">
              <svg class="faq-icon-plus" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              <svg class="faq-icon-minus" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </span>
          </summary>
          <div class="faq-answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <div style="text-align:center;margin-top:52px" class="reveal">
      <a href="#utmCaptureForm" class="btn-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        AINDA TEM DÚVIDAS? FALE CONOSCO
      </a>
    </div>

  </div>
</section>

<style>
  .faq-list { display: flex; flex-direction: column; gap: 12px; }

  .faq-item {
    border: 1px solid rgba(196,163,110,0.15);
    border-radius: 14px;
    background: rgba(255,255,255,0.03);
    overflow: hidden;
    transition: border-color 0.25s ease, background 0.25s ease;
  }
  .faq-item[open] {
    border-color: rgba(196,163,110,0.35);
    background: rgba(196,163,110,0.04);
  }

  .faq-question {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background 0.2s ease;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question:hover { background: rgba(255,255,255,0.03); }

  .faq-q-num {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--lp-gold);
    opacity: 0.55;
    flex-shrink: 0;
    min-width: 28px;
    line-height: 1;
  }

  .faq-q-text {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: #F7F4EF;
    line-height: 1.4;
    flex: 1;
  }

  .faq-icon {
    flex-shrink: 0;
    color: var(--lp-gold);
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(196,163,110,0.25);
    transition: background 0.2s, border-color 0.2s;
  }
  .faq-item[open] .faq-icon {
    background: rgba(196,163,110,0.12);
    border-color: rgba(196,163,110,0.4);
  }

  /* Alterna ícone + / − */
  .faq-icon-plus  { display: block; }
  .faq-icon-minus { display: none; }
  .faq-item[open] .faq-icon-plus  { display: none; }
  .faq-item[open] .faq-icon-minus { display: block; }

  .faq-answer {
    padding: 0 24px 22px calc(24px + 28px + 16px);
  }
  .faq-answer p {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: rgba(232,231,218,0.62);
    line-height: 1.8;
    margin: 0;
  }

  @media (max-width: 640px) {
    .faq-question { padding: 16px 18px; gap: 12px; }
    .faq-q-text { font-size: 14px; }
    .faq-answer { padding: 0 18px 18px calc(18px + 28px + 12px); }
  }
</style>
