---
import { CLIENT } from '@/config/client';

const { doctors } = CLIENT;
const singleDoctor = doctors.length === 1;
---

{doctors.map((doc, idx) => {
  const photoLeft = !singleDoctor && idx % 2 === 1;
  const bio = 'bio' in doc ? (doc as any).bio as string[] : [];
  const eyebrow = singleDoctor ? 'Sobre mim' : 'Nossos Especialistas';

  return (
    <section class={`lp-doc-section lp-section-pad${idx % 2 === 1 ? ' lp-doc-section--alt' : ''}`}>
      <div class="lp-section-inner">
        <div class={`lp-doc-grid${photoLeft ? ' lp-doc-grid--reversed' : ''}`}>

          <!-- Foto -->
          <div class="lp-doc-photo-side reveal">
            <div class="lp-doc-frame">
              <img
                src={doc.photo}
                alt={doc.name}
                loading={idx === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="lp-doc-img"
              />
              <div class="lp-doc-frame-border" aria-hidden="true"></div>
            </div>
          </div>

          <!-- Conteúdo -->
          <div class="lp-doc-content reveal">
            <span class="lp-eyebrow" style="text-align:left;margin-bottom:14px;">{eyebrow}</span>

            <h2 class="lp-doc-name">{doc.name}</h2>

            <p class="lp-doc-specialty"><em>{doc.specialty}</em></p>

            {doc.crm && (
              <span class="lp-doc-crm">{doc.crm}</span>
            )}

            {bio.length > 0 && (
              <div class="lp-doc-bio">
                {bio.map((para: string) => <p>{para}</p>)}
              </div>
            )}

            <ul class="lp-doc-creds-list">
              {doc.credentials.map(cred => (
                <li>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--lp-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  <span>{cred}</span>
                </li>
              ))}
            </ul>

            <a href="#utmCaptureForm" class="btn-cta lp-doc-cta">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              AGENDAR CONSULTA
            </a>
          </div>

        </div>
      </div>
    </section>
  );
})}

<style>
  /* ── Seção ── */
  .lp-doc-section {
    background: var(--lp-dark);
  }
  .lp-doc-section--alt {
    background: #141110;
  }

  /* ── Grid 2 colunas ── */
  .lp-doc-grid {
    display: grid;
    grid-template-columns: 48fr 52fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }
  .lp-doc-grid--reversed .lp-doc-photo-side { order: 2; }
  .lp-doc-grid--reversed .lp-doc-content    { order: 1; }

  /* ── Foto ── */
  .lp-doc-photo-side {
    position: relative;
  }
  .lp-doc-frame {
    position: relative;
    border-radius: 18px;
    overflow: visible;
  }
  .lp-doc-img {
    width: 100%;
    height: auto;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top center;
    border-radius: 18px;
    display: block;
    position: relative;
    z-index: 1;
    box-shadow: 0 32px 80px rgba(0,0,0,0.55);
  }
  /* Borda dourada offset — frame decorativo */
  .lp-doc-frame-border {
    position: absolute;
    inset: -10px -10px 10px 10px;
    border: 1.5px solid rgba(196,163,110,0.35);
    border-radius: 22px;
    z-index: 0;
    pointer-events: none;
    transition: border-color 0.4s ease;
  }
  .lp-doc-frame:hover .lp-doc-frame-border {
    border-color: rgba(196,163,110,0.6);
  }
  .lp-doc-frame:hover .lp-doc-img {
    transform: translate(-3px, -3px);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .lp-doc-img {
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }

  /* ── Conteúdo ── */
  .lp-doc-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .lp-doc-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 400;
    color: #F7F4EF;
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
  }
  .lp-doc-specialty {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 400;
    color: var(--lp-gold);
    margin: 0 0 14px;
    line-height: 1.3;
  }
  .lp-doc-specialty em { font-style: italic; }
  .lp-doc-crm {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lp-gold);
    border: 1px solid rgba(196,163,110,0.3);
    border-radius: 4px;
    padding: 4px 10px;
    margin-bottom: 28px;
  }
  .lp-doc-bio {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 28px;
  }
  .lp-doc-bio p {
    font-family: var(--font-body);
    font-size: 15px;
    color: rgba(232,231,218,0.68);
    line-height: 1.75;
    margin: 0;
  }
  .lp-doc-creds-list {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .lp-doc-creds-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 13.5px;
    color: rgba(232,231,218,0.75);
    line-height: 1.55;
  }
  .lp-doc-cta {
    align-self: flex-start;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .lp-doc-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .lp-doc-grid--reversed .lp-doc-photo-side,
    .lp-doc-grid--reversed .lp-doc-content { order: unset; }
    .lp-doc-photo-side { order: -1; }
    .lp-doc-img { aspect-ratio: 4/3; }
    .lp-doc-cta { align-self: stretch; justify-content: center; }
    .lp-doc-crm { margin-bottom: 20px; }
    .lp-doc-bio { margin-bottom: 20px; }
    .lp-doc-creds-list { margin-bottom: 24px; }
  }
</style>
